<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PubliShelf - Your Digital Book Marketplace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="bg-gray-50 font-sans">
    <!-- Navbar -->
    <nav class="fixed w-full bg-white/80 backdrop-blur-md shadow-sm z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/" class="flex items-center">
                        <span
                            class="text-2xl font-bold bg-gradient-to-r from-purple-600 to-indigo-600 text-transparent bg-clip-text">PubliShelf</span>
                    </a>
                </div>
                <div class="hidden md:flex items-center space-x-8">
                    <div class="relative group">
                        <button
                            class="text-gray-700 hover:text-purple-600 transition-colors px-3 py-2">Categories</button>
                        <div
                            class="absolute top-full left-0 w-48 bg-white shadow-lg rounded-lg py-2 hidden group-hover:block">
                            <a href="#" class="<%= styles.categoryBtnStyle %>">Young Adult</a>
                            <a href="#" class="<%= styles.categoryBtnStyle %>">Fantasy</a>
                            <a href="#" class="<%= styles.categoryBtnStyle %>">Sci-Fi</a>
                            <a href="#" class="<%= styles.categoryBtnStyle %>">Thrillers</a>
                            <a href="#" class="<%= styles.categoryBtnStyle %>">Romance</a>
                        </div>
                    </div>
                    <a href="/#faq-section" class="<%= styles.navBtnStyle %>">FAQ</a>
                    <a href="/about" class="<%= styles.navBtnStyle %>">About</a>
                    <a href="/contact" class="<%= styles.navBtnStyle %>">Contact Us</a>
                    <a href="/buyer/dashboard" class="<%= styles.navBtnStyle %>">Bookstores</a>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="#" class="text-gray-700 hover:text-purple-600 scale-0 md:scale-100">
                        <i class="far fa-heart"></i>
                    </a>
                    <a href="#" class="text-gray-700 hover:text-purple-6000 scale-0 md:scale-100">
                        <i class="fas fa-shopping-cart"></i>
                    </a>
                    <button onclick="window.location.href='/auth/login'"
                        class="bg-gradient-to-r hover:bg-gradient-to-l from-purple-600 to-indigo-600 text-white px-4 py-2 rounded-lg hover:-translate-y-[2px] transition-all duration-300">Join
                        Now</button>
                    <div class="relative group">
                        <button class="md:hidden text-gray-700 hover:text-purple-600 transition-colors px-3 py-2"><img class="h-6 w-6" src="https://img.icons8.com/?size=100&id=3096&format=png&color=000000" alt="="></button>
                        <div
                            class="absolute top-full right-1 w-32 bg-white shadow-lg rounded-lg py-2 hidden group-hover:block">
                            <a href="#" class="<%= styles.categoryBtnStyle %>">Cart</a>
                            <a href="#" class="<%= styles.categoryBtnStyle %>">WishList</a>
                            <a href="/#faq-section" class="<%= styles.categoryBtnStyle %>">FAQ</a>
                            <a href="/about" class="<%= styles.categoryBtnStyle %>">About</a>
                            <a href="/contact" class="<%= styles.categoryBtnStyle %>">Contact Us</a>
                            <a href="/buyer/dashboard" class="<%= styles.categoryBtnStyle %>">Bookstores</a>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="pt-40 pb-12 bg-gradient-to-b from-purple-50 to-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h1 class="text-5xl font-bold text-gray-900 mb-6 animate-fade-in mt-16">
                    Discover Your Next Literary Adventure
                </h1>
                <p class="text-xl text-gray-600 mb-8 animate-fade-in-delay">
                    Join thousands of readers in the world's most vibrant book marketplace
                </p>
                <div class="h-7"></div>
                <div class="flex justify-center space-x-4 animate-fade-in-delay-2">
                    <button onclick="window.location.href='/auth/login'"
                        class="bg-purple-600 text-white px-8 py-3 font-semibold rounded-lg hover:bg-purple-700 transform transition-all duration-300 hover:-translate-y-1">
                        Start Reading
                    </button>
                    <button onclick="window.location.href='/publisher/signup'"
                        class="bg-white text-purple-600 px-8 py-3 font-semibold rounded-lg border-2 border-purple-600 hover:bg-purple-50 transform transition-all duration-300 hover:-translate-y-1">
                        Sell Your Books
                    </button>
                </div>
            </div>
        </div>
        <div class="h-3"></div>
    </section>

    <!-- PubliShelf Introduction Section -->
    <section class="py-12 bg-white font">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h2 class="text-3xl font-bold text-gray-900 mb-6">
                    PubliShelf - Your Gateway to a World of Books
                </h2>
                <p class="text-md text-gray-600 mb-8">
                    Are you a college student tired of the pile of used books accumulating after every semester? Or perhaps a book lover with shelves full of books you’ve read and forgotten? If so, PubliShelf is here to transform your book journey!
                </p>
                <p class="text-md text-gray-600 mb-8">
                    PubliShelf is India’s premier platform where you can buy and sell used books effortlessly. Whether you’re looking to declutter your bookshelf or find your next literary treasure, PubliShelf connects book lovers like you in a seamless and rewarding way.
                </p>
                <p class="text-md text-gray-600 mb-8">
                    But that’s not all! PubliShelf also offers a unique antique book auction feature, where rare and vintage books find new homes with collectors and enthusiasts.
                </p>
            </div>
        </div>
    </section>

    <!-- Why Choose PubliShelf Section -->
    <section class="py-12 bg-gray-50">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Why Choose PubliShelf?</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="text-center">
                    <h3 class="text-xl font-bold text-purple-600 mb-4">For Sellers</h3>
                    <p class="text-gray-600">Turn your old books into cash! Sell your used books at prices you set and reach a community of eager readers.</p>
                </div>
                <div class="text-center">
                    <h3 class="text-xl font-bold text-purple-600 mb-4">For Buyers</h3>
                    <p class="text-gray-600">Discover affordable second-hand books in great condition, directly from other book lovers.</p>
                </div>
                <div class="text-center">
                    <h3 class="text-xl font-bold text-purple-600 mb-4">For Collectors</h3>
                    <p class="text-gray-600">Dive into our exclusive antique book auctions and bid on rare, vintage, and collectible books.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Books Sections -->
    <section class="py-12 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Top Rated Books</h2>
            <div class="book-carousel" id="topRatedCarousel">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <% books.topRated.forEach(book=> { %>
                        <div class="<%= styles.bookCardStyle %>" onclick="window.location.href='/buyer/product-detail'">
                            <img src="<%= book.image %>" alt="<%= book.title %>" class="w-full h-40 object-cover">
                            <div class="p-3">
                                <h3 class="text-lg font-semibold mb-1 truncate">
                                    <%= book.title %>
                                </h3>
                                <p class="text-gray-600 text-sm mb-2">by <%= book.author %>
                                </p>
                                <div class="flex justify-between items-center">
                                    <div class="flex items-center">
                                        <span class="text-yellow-400">★</span>
                                        <span class="ml-1 text-sm">
                                            <%= book.rating %>
                                        </span>
                                    </div>
                                    <span class="font-bold text-purple-600 text-sm">
                                        <%= book.price %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>
        </div>
    </section>

    <!-- Most Sold Books Section -->
    <section class="py-12 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Most Sold Books</h2>
            <div class="book-carousel" id="mostSoldCarousel">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <% books.mostSold.forEach(book=> { %>
                        <div class="<%= styles.bookCardStyle %>">
                            <img src="<%= book.image %>" alt="<%= book.title %>" class="w-full h-40 object-cover">
                            <div class="p-3">
                                <h3 class="text-lg font-semibold mb-1 truncate">
                                    <%= book.title %>
                                </h3>
                                <p class="text-gray-600 text-sm mb-2">by <%= book.author %>
                                </p>
                                <div class="flex justify-between items-center">
                                    <div class="flex items-center">
                                        <span class="text-purple-600 text-sm">
                                            <%= book.sales %>
                                        </span>
                                    </div>
                                    <span class="font-bold text-purple-600 text-sm">
                                        <%= book.price %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>
        </div>
    </section>

    <!-- Trending Books Section -->
    <section class="py-12 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Trending Now</h2>
            <div class="book-carousel" id="trendingCarousel">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <% books.trending.forEach(book=> { %>
                        <div class="<%= styles.bookCardStyle %>">
                            <div class="relative">
                                <img src="<%= book.image %>" alt="<%= book.title %>" class="w-full h-40 object-cover">
                                <div
                                    class="absolute top-2 right-2 bg-red-500 text-white px-2 py-1 rounded-full text-xs">
                                    <%= book.trending %>
                                </div>
                            </div>
                            <div class="p-3">
                                <h3 class="text-lg font-semibold mb-1 truncate">
                                    <%= book.title %>
                                </h3>
                                <p class="text-gray-600 text-sm mb-2">by <%= book.author %>
                                </p>
                                <div class="flex justify-between items-center">
                                    <span class="text-purple-600 text-sm">Trending</span>
                                    <span class="font-bold text-purple-600 text-sm">
                                        <%= book.price %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq-section" class="py-12 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Frequently Asked Questions</h2>
            <div class="max-w-3xl mx-auto">
                <div class="space-y-4">
                    <div class="<%= styles.faqBtnStyle %>" id="faq-item">
                        <button
                            class="w-full flex justify-between items-center p-4 bg-gray-50 rounded-lg hover:bg-gray-100">
                            <span class="font-semibold">How do I sell my books?</span>
                            <i class="fas fa-chevron-down"></i>
                        </button>
                        <div class="<%= styles.faqContentStyle %>" id="faq-content">
                            <p class="text-gray-600">Sign up as a seller, list your books with details and photos, set
                                your price, and start selling to our community of book lovers.</p>
                        </div>
                    </div>
                    <div class="<%= styles.faqBtnStyle %> " id="faq-item">
                        <button
                            class="w-full flex justify-between items-center p-4 bg-gray-50 rounded-lg hover:bg-gray-100">
                            <span class="font-semibold">What payment methods are accepted?</span>
                            <i class="fas fa-chevron-down"></i>
                        </button>
                        <div class="<%= styles.faqContentStyle %>" id="faq-content">
                            <p class="text-gray-600">We accept all major credit cards, PayPal, and various digital
                                payment methods for your convenience.</p>
                        </div>
                    </div>
                    <div class="<%= styles.faqBtnStyle %> " id="faq-item">
                        <button
                            class="w-full flex justify-between items-center p-4 bg-gray-50 rounded-lg hover:bg-gray-100">
                            <span class="font-semibold">How does shipping work?</span>
                            <i class="fas fa-chevron-down"></i>
                        </button>
                        <div class="<%= styles.faqContentStyle %>" id="faq-content">
                            <p class="text-gray-600">Sellers handle shipping. Most items are shipped within 2-3 business
                                days, and tracking information is provided once available.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div>
                    <h3 class="text-xl font-bold mb-4">PubliShelf</h3>
                    <p class="text-gray-400">Your gateway to endless literary discoveries.</p>
                </div>
                <div>
                    <h4 class="text-lg font-semibold mb-4">Quick Links</h4>
                    <ul class="space-y-2">
                        <li><a href="/about" class="text-gray-400 hover:text-white">About Us</a></li>
                        <li><a href="/contact" class="text-gray-400 hover:text-white">Contact</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white">Terms of Service</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white">Privacy Policy</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-lg font-semibold mb-4">Connect</h4>
                    <div class="flex space-x-4">
                        <a href="#" class="text-gray-400 hover:text-white"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-gray-400 hover:text-white"><i class="fab fa-facebook"></i></a>
                        <a href="#" class="text-gray-400 hover:text-white"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-gray-400 hover:text-white"><i class="fab fa-linkedin"></i></a>
                    </div>
                </div>
                <div>
                    <h4 class="text-lg font-semibold mb-4">Newsletter</h4>
                    <form class="flex">
                        <input type="email" placeholder="Enter your email"
                            class="px-4 py-2 rounded-l-lg w-full focus:outline-none focus:outline-purple-500">
                        <button class="bg-purple-600 px-4 py-2 rounded-r-lg hover:bg-purple-700">
                            Subscribe
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </footer>

    <script src="/js/script.js"></script>
</body>

</html>