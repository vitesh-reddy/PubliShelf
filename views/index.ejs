<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PubliShelf - Your Digital Book Marketplace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="bg-gray-50 font-sans">
    <!-- Navbar -->
    <nav class="fixed w-full bg-white/80 backdrop-blur-md shadow-sm z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/" class="flex items-center">
                        <span
                            class="text-2xl font-bold bg-gradient-to-r from-purple-600 to-indigo-600 text-transparent bg-clip-text">PubliShelf</span>
                    </a>
                </div>
                <div class="hidden md:flex items-center space-x-8">
                    <div class="relative group">
                        <button
                            class="text-gray-700 hover:text-purple-600 transition-colors px-3 py-2">Categories</button>
                        <% console.log(styles); %>
                            <div
                                class="absolute top-full left-0 w-48 bg-white shadow-lg rounded-lg py-2 hidden group-hover:block">
                                <a href="#" class="<%= styles.categoryBtnStyle %>">Young Adult</a>
                                <a href="#" class="<%= styles.categoryBtnStyle %>" hover:bg-purple-50">Fantasy</a>
                                <a href="#" class="<%= styles.categoryBtnStyle %>" hover:bg-purple-50">Sci-Fi</a>
                                <a href="#" class="<%= styles.categoryBtnStyle %>" hover:bg-purple-50">Thrillers</a>
                                <a href="#" class="<%= styles.categoryBtnStyle %>" hover:bg-purple-50">Romance</a>
                            </div>
                    </div>
                    <a href="#" class="<%= styles.navBtnStyle %>">About</a>
                    <a href="#" class="<%= styles.navBtnStyle %>">FAQ</a>
                    <a href="#" class="<%= styles.navBtnStyle %>">Blog</a>
                    <a href="/buyer/dashboard" class="<%= styles.navBtnStyle %>">Bookstores</a>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="#" class="text-gray-700 hover:text-purple-600">
                        <i class="far fa-heart"></i>
                    </a>
                    <a href="#" class="text-gray-700 hover:text-purple-600">
                        <i class="fas fa-shopping-cart"></i>
                    </a>
                    <button class="<%= styles.purpleBtnStyle %>">Sign
                        In</button>
                    <button class="<%= styles.indigoBtnStyle %>">Sign
                        Up</button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="pt-40 pb-12 bg-gradient-to-b from-purple-50 to-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h1 class="text-5xl font-bold text-gray-900 mb-6 animate-fade-in mt-16">
                    Discover Your Next Literary Adventure
                </h1>
                <p class="text-xl text-gray-600 mb-8 animate-fade-in-delay">
                    Join thousands of readers in the world's most vibrant book marketplace
                </p>
                <div class="flex justify-center space-x-4 animate-fade-in-delay-2">
                    <button
                        class="bg-purple-600 text-white px-8 py-3 rounded-lg hover:bg-purple-700 transition-transform hover:translate-y-[-4px]">
                        Start Reading
                    </button>
                    <button
                        class="bg-white text-purple-600 px-8 py-3 rounded-lg border-2 border-purple-600 hover:bg-purple-50 transition-transform hover:translate-y-[-4px]">
                        Sell Your Books
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="py-12 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-4 gap-8 text-center">
                <div class="stat-card">
                    <div class="text-3xl font-bold text-purple-600 counter" data-target="1000000">0</div>
                    <div class="text-gray-600">Books Available</div>
                </div>
                <div class="stat-card">
                    <div class="text-3xl font-bold text-purple-600 counter" data-target="500000">0</div>
                    <div class="text-gray-600">Active Readers</div>
                </div>
                <div class="stat-card">
                    <div class="text-3xl font-bold text-purple-600 counter" data-target="50000">0</div>
                    <div class="text-gray-600">Publishers</div>
                </div>
                <div class="stat-card">
                    <div class="text-3xl font-bold text-purple-600 counter" data-target="2000000">0</div>
                    <div class="text-gray-600">Books Sold</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Books Sections -->
    <section class="py-12 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Top Rated Books</h2>
            <div class="book-carousel" id="topRatedCarousel">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <% books.topRated.forEach(book=> { %>
                        <div class="book-card bg-white rounded-lg shadow-md overflow-hidden">
                            <img src="<%= book.image %>" alt="<%= book.title %>" class="w-full h-40 object-cover">
                            <div class="p-3">
                                <h3 class="text-lg font-semibold mb-1 truncate">
                                    <%= book.title %>
                                </h3>
                                <p class="text-gray-600 text-sm mb-2">by <%= book.author %>
                                </p>
                                <div class="flex justify-between items-center">
                                    <div class="flex items-center">
                                        <span class="text-yellow-400">★</span>
                                        <span class="ml-1 text-sm">
                                            <%= book.rating %>
                                        </span>
                                    </div>
                                    <span class="font-bold text-purple-600 text-sm">
                                        <%= book.price %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>
        </div>
    </section>

    <!-- Most Sold Books Section -->
    <section class="py-12 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Most Sold Books</h2>
            <div class="book-carousel" id="mostSoldCarousel">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <% books.mostSold.forEach(book=> { %>
                        <div class="book-card bg-gray-50 rounded-lg shadow-md overflow-hidden">
                            <img src="<%= book.image %>" alt="<%= book.title %>" class="w-full h-40 object-cover">
                            <div class="p-3">
                                <h3 class="text-lg font-semibold mb-1 truncate">
                                    <%= book.title %>
                                </h3>
                                <p class="text-gray-600 text-sm mb-2">by <%= book.author %>
                                </p>
                                <div class="flex justify-between items-center">
                                    <div class="flex items-center">
                                        <span class="text-purple-600 text-sm">
                                            <%= book.sales %>
                                        </span>
                                    </div>
                                    <span class="font-bold text-purple-600 text-sm">
                                        <%= book.price %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>
        </div>
    </section>

    <!-- Trending Books Section -->
    <section class="py-12 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Trending Now</h2>
            <div class="book-carousel" id="trendingCarousel">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <% books.trending.forEach(book=> { %>
                        <div class="book-card bg-white rounded-lg shadow-md overflow-hidden">
                            <div class="relative">
                                <img src="<%= book.image %>" alt="<%= book.title %>" class="w-full h-40 object-cover">
                                <div
                                    class="absolute top-2 right-2 bg-red-500 text-white px-2 py-1 rounded-full text-xs">
                                    <%= book.trending %>
                                </div>
                            </div>
                            <div class="p-3">
                                <h3 class="text-lg font-semibold mb-1 truncate">
                                    <%= book.title %>
                                </h3>
                                <p class="text-gray-600 text-sm mb-2">by <%= book.author %>
                                </p>
                                <div class="flex justify-between items-center">
                                    <span class="text-purple-600 text-sm">Trending</span>
                                    <span class="font-bold text-purple-600 text-sm">
                                        <%= book.price %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-12 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Frequently Asked Questions</h2>
            <div class="max-w-3xl mx-auto">
                <div class="space-y-4">
                    <div class="faq-item">
                        <button
                            class="w-full flex justify-between items-center p-4 bg-gray-50 rounded-lg hover:bg-gray-100">
                            <span class="font-semibold">How do I sell my books?</span>
                            <i class="fas fa-chevron-down"></i>
                        </button>
                        <div class="faq-content hidden p-4">
                            <p class="text-gray-600">Sign up as a seller, list your books with details and photos, set
                                your price, and start selling to our community of book lovers.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button
                            class="w-full flex justify-between items-center p-4 bg-gray-50 rounded-lg hover:bg-gray-100">
                            <span class="font-semibold">What payment methods are accepted?</span>
                            <i class="fas fa-chevron-down"></i>
                        </button>
                        <div class="faq-content hidden p-4">
                            <p class="text-gray-600">We accept all major credit cards, PayPal, and various digital
                                payment methods for your convenience.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button
                            class="w-full flex justify-between items-center p-4 bg-gray-50 rounded-lg hover:bg-gray-100">
                            <span class="font-semibold">How does shipping work?</span>
                            <i class="fas fa-chevron-down"></i>
                        </button>
                        <div class="faq-content hidden p-4">
                            <p class="text-gray-600">Sellers handle shipping. Most items are shipped within 2-3 business
                                days, and tracking information is provided once available.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div>
                    <h3 class="text-xl font-bold mb-4">PubliShelf</h3>
                    <p class="text-gray-400">Your gateway to endless literary discoveries.</p>
                </div>
                <div>
                    <h4 class="text-lg font-semibold mb-4">Quick Links</h4>
                    <ul class="space-y-2">
                        <li><a href="#" class="text-gray-400 hover:text-white">About Us</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white">Contact</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white">Terms of Service</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white">Privacy Policy</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-lg font-semibold mb-4">Connect</h4>
                    <div class="flex space-x-4">
                        <a href="#" class="text-gray-400 hover:text-white"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-gray-400 hover:text-white"><i class="fab fa-facebook"></i></a>
                        <a href="#" class="text-gray-400 hover:text-white"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-gray-400 hover:text-white"><i class="fab fa-linkedin"></i></a>
                    </div>
                </div>
                <div>
                    <h4 class="text-lg font-semibold mb-4">Newsletter</h4>
                    <form class="flex">
                        <input type="email" placeholder="Enter your email" class="px-4 py-2 rounded-l-lg w-full">
                        <button class="bg-purple-600 px-4 py-2 rounded-r-lg hover:bg-purple-700">
                            Subscribe
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </footer>

    <script src="/js/script.js"></script>
</body>

</html>