                    <button id="privacy-link" class="text-gray-300 hover:text-purple-400 text-sm">Privacy
                        Policy</button>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // Mock auction data
        const auctions = [
            { id: 1, endTime: new Date('2025-05-07T23:59:59Z'), wishlist: false },
            { id: 2, endTime: new Date('2025-05-08T23:59:59Z'), wishlist: false },
            { id: 3, endTime: new Date('2025-05-09T23:59:59Z'), wishlist: false },
        ];

        // Update countdown timers
        function updateCountdown() {
            auctions.forEach(auction => {
                const now = new Date();
                const element = document.getElementById(`countdown-${auction.id}`);
                if (now < auction.endTime) {
                    const diff = auction.endTime - now;
                    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((diff % (1000 * 60)) / 1000);
                    element.textContent = `${days}d ${hours}h ${minutes}m ${seconds}s`;
                } else {
                    element.textContent = 'Auction Ended';
                }
            });
        }

        // Toggle wishlist
        function toggleWishlist(id) {
            const auction = auctions.find(a => a.id === id);
            auction.wishlist = !auction.wishlist;
            const icon = document.getElementById(`wishlist-icon-${id}`);
            icon.className = auction.wishlist ? 'fas fa-heart text-red-500' : 'far fa-heart';
        }

        // Terms and Conditions and Privacy Policy modal handling
        const tncModal = document.getElementById('tnc-modal');
        const privacyModal = document.getElementById('privacy-modal');
        const tncLink = document.getElementById('tnc-link');
        const privacyLink = document.getElementById('privacy-link');
        const tncClose = document.getElementById('tnc-modal-close');
        const privacyClose = document.getElementById('privacy-modal-close');

        tncLink.addEventListener('click', () => {
            tncModal.classList.remove('hidden');
        });

        privacyLink.addEventListener('click', () => {
            privacyModal.classList.remove('hidden');
        });

        tncClose.addEventListener('click', () => {
            tncModal.classList.add('hidden');
        });

        privacyClose.addEventListener('click', () => {
            privacyModal.classList.add('hidden');
        });

        setInterval(updateCountdown, 1000);
        updateCountdown();
    </script>