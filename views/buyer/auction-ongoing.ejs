    <script>
        // Mock auction data
        const auctionStart = new Date('2025-05-05T10:00:00Z');
        const auctionEnd = new Date('2025-05-07T23:59:59Z');
        let currentBid = 7500;
        const minIncrement = 100;
        const buyerId = 'mock_buyer_id'; // Replace with actual buyer ID from session
        const auctionId = '1';
        const buyerName = 'Buyer Name'; // Replace with actual buyer name from session

        // Update countdown and progress bar
        function updateCountdown() {
            const now = new Date();
            const countdownElement = document.getElementById('countdown');
            const bidButton = document.getElementById('enter-bid');
            const progressBar = document.getElementById('progress-bar');
            const progressPercent = document.getElementById('progress-percent');

            if (now < auctionEnd) {
                const diff = auctionEnd - now;
                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((diff % (1000 * 60)) / 1000);
                countdownElement.textContent = `${days}d ${hours}h ${minutes}m ${seconds}s`;

                const totalDuration = auctionEnd - auctionStart;
                const elapsed = now - auctionStart;
                const progress = Math.min((elapsed / totalDuration) * 100, 100);
                progressBar.style.width = `${progress}%`;
                progressPercent.textContent = `${Math.round(progress)}%`;
            } else {
                countdownElement.textContent = 'Auction Ended';
                progressBar.style.width = '100%';
                progressPercent.textContent = '100%';
                bidButton.disabled = true;
                bidButton.classList.remove('bg-purple-600', 'hover:bg-purple-700');
                bidButton.classList.add('bg-gray-400', 'cursor-not-allowed');
                bidButton.textContent = 'Auction Ended';
            }
        }

        // Format date for display
        function formatDate(date) {
            return date.toLocaleString('en-US', {
                month: 'short',
                day: '2-digit',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit',
            });
        }

        // Add new bid to history
        function addBidToHistory(bidderName, amount, time, isTopBidder) {
            const historyDiv = document.getElementById('bidding-history');
            const bidEntry = document.createElement('div');
            bidEntry.className = `flex items-center justify-between border-b pb-2 ${isTopBidder ? 'bg-purple-100 rounded-md px-3' : ''} animate-fade-in`;
            bidEntry.innerHTML = `
                <div class="flex items-center space-x-3">
                    <img src="https://ui-avatars.com/api/?name=${encodeURIComponent(bidderName)}" alt="${bidderName}" class="w-8 h-8 rounded-full">
                    <div>
                        <p class="font-semibold text-sm">${bidderName} ${isTopBidder ? '<span class="text-purple-600 text-xs">(Top Bidder)</span>' : ''}</p>
                        <p class="text-gray-500 text-xs">${time}</p>
                    </div>
                </div>
                <p class="font-bold text-purple-600 text-sm">₹${amount}</p>
            `;
            historyDiv.insertBefore(bidEntry, historyDiv.firstChild);
        }

        // Document carousel
        const carousel = document.getElementById('document-carousel');
        const prevBtn = document.getElementById('carousel-prev');
        const nextBtn = document.getElementById('carousel-next');
        prevBtn.addEventListener('click', () => {
            carousel.scrollBy({ left: -100, behavior: 'smooth' });
        });
        nextBtn.addEventListener('click', () => {
            carousel.scrollBy({ left: 100, behavior: 'smooth' });
        });

        // Bid increment slider
        const bidInput = document.getElementById('bid-amount');
        const incrementSlider = document.getElementById('bid-increment');
        incrementSlider.addEventListener('input', () => {
            bidInput.value = currentBid + parseInt(incrementSlider.value);
        });

        // Bid modal handling
        const bidModal = document.getElementById('bid-modal');
        const modalBidAmount = document.getElementById('modal-bid-amount');
        const modalConfirm = document.getElementById('modal-confirm');
        const modalCancel = document.getElementById('modal-cancel');
        const enterBidBtn = document.getElementById('enter-bid');
        const errorMessage = document.getElementById('error-message');

        enterBidBtn.addEventListener('click', () => {
            const bidAmount = parseInt(bidInput.value);
            if (isNaN(bidAmount) || bidAmount < currentBid + minIncrement) {
                errorMessage.classList.remove('hidden');
                return;
            }
            errorMessage.classList.add('hidden');
            modalBidAmount.textContent = `₹${bidAmount}`;
            bidModal.classList.remove('hidden');
        });

        modalCancel.addEventListener('click', () => {
            bidModal.classList.add('hidden');
        });

        modalConfirm.addEventListener('click', async () => {
            const bidAmount = parseInt(bidInput.value);
            bidModal.classList.add('hidden');

            try {
                const response = await fetch(`/api/auctions/${auctionId}/bid`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ bidAmount, bidder: buyerId }),
                });

                if (!response.ok) throw new Error('Bid submission failed');

                const data = await response.json();
                currentBid = bidAmount;
                document.getElementById('current-bid').textContent = `₹${currentBid}`;
                bidInput.min = currentBid + minIncrement;
                bidInput.placeholder = `Enter bid (min ₹${currentBid + minIncrement})`;
                bidInput.value = '';
                incrementSlider.value = minIncrement;

                // Update bidding history
                const bidTime = formatDate(new Date());
                const historyDiv = document.getElementById('bidding-history');
                historyDiv.innerHTML = '';
                addBidToHistory(buyerName, bidAmount, bidTime, true);
                [
                    { name: 'Sarah Smith', amount: 7200, time: 'May 06, 2025, 14:15' },
                    { name: 'Michael Chen', amount: 7000, time: 'May 06, 2025, 14:00' },
                ].forEach(bid => addBidToHistory(bid.name, bid.amount, bid.time, false));
            } catch (error) {
                console.error('Error submitting bid:', error);
                errorMessage.textContent = 'Failed to submit bid. Please try again.';
                errorMessage.classList.remove('hidden');
            }
        });

        // Terms and Conditions and Privacy Policy modal handling
        const tncModal = document.getElementById('tnc-modal');
        const privacyModal = document.getElementById('privacy-modal');
        const tncLink = document.getElementById('tnc-link');
        const privacyLink = document.getElementById('privacy-link');
        const tncClose = document.getElementById('tnc-modal-close');
        const privacyClose = document.getElementById('privacy-modal-close');

        tncLink.addEventListener('click', () => {
            tncModal.classList.remove('hidden');
        });

        privacyLink.addEventListener('click', () => {
            privacyModal.classList.remove('hidden');
        });

        tncClose.addEventListener('click', () => {
            tncModal.classList.add('hidden');
        });

        privacyClose.addEventListener('click', () => {
            privacyModal.classList.add('hidden');
        });

        setInterval(updateCountdown, 1000);
        updateCountdown();
    </script>
    <style>
        @keyframes fade-in {
            from {
                opacity: 0;
                transform: translateY(-8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-fade-in {
            animation: fade-in 0.3s ease-out;
        }

        input[type="range"]::-webkit-slider-thumb {
            appearance: none;
            width: 12px;
            height: 12px;
            background: #9333ea;
            border-radius: 50%;
            cursor: pointer;
        }

        input[type="range"]::-moz-range-thumb {
            width: 12px;
            height: 12px;
            background: #9333ea;
            border-radius: 50%;
            cursor: pointer;
        }
    </style>