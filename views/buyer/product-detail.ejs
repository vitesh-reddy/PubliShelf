<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Details - PubliShelf</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="bg-gray-50">
    <!-- Navbar -->
    <nav class="fixed w-full bg-white shadow-sm z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/" class="flex items-center">
                        <span
                            class="text-2xl font-bold bg-gradient-to-r from-purple-600 to-indigo-600 text-transparent bg-clip-text">PubliShelf</span>
                    </a>
                </div>
                <div class="flex items-center space-x-8">
                    <div class="relative">
                        <input type="text" placeholder="Search books..."
                            class="w-64 px-4 py-2 rounded-lg border focus:outline-none focus:ring-2 focus:ring-purple-600">
                        <button class="absolute right-3 top-2.5 text-gray-400">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                    <a href="#" class="text-gray-700 hover:text-purple-600">
                        <i class="far fa-heart"></i>
                    </a>
                    <a href="#" class="text-gray-700 hover:text-purple-600">
                        <i class="fas fa-shopping-cart"></i>
                    </a>
                    <div class="relative">
                        <button class="flex items-center space-x-2">
                            <img src="https://img.icons8.com/?size=100&id=zxB19VPoVLjK&format=png&color=000000" class="w-6 h-6" alt="Profile"
                                class="w-8 h-8 rounded-full">
                            <span class="text-gray-700"><%= name %></span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="pt-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <!-- Breadcrumb -->
            <nav class="flex mb-8" aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-3">
                    <li class="inline-flex items-center">
                        <a href="/buyer/dashboard" class="text-gray-700 hover:text-purple-600">
                            <i class="fas fa-home mr-2"></i>
                            Home
                        </a>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="fas fa-chevron-right text-gray-400 mx-2"></i>
                            <span class="text-gray-500"><%= book.bookTitle %></span>
                        </div>
                    </li>
                </ol>
            </nav>

            <!-- Product Details -->
            <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8">
                    <!-- Image Section -->
                    <div class="space-y-4">
                        <div class="aspect-w-3 aspect-h-4 rounded-lg overflow-hidden">
                            <img src="<%= book.image %>"
                                alt="The Midnight Library"
                                class="w-full h-full object-cover transform transition-transform duration-500 hover:scale-110">
                        </div>
                        <!--  -->
                    </div>

                    <!-- Product Info -->
                    <div class="space-y-6">
                        <div>
                            <h1 class="text-3xl font-bold text-gray-900"><%= book.bookTitle %></h1>
                            <p class="text-lg text-gray-600 mt-2"><%= book.author %></p>
                            <p class="text-gray-600">Genre : <%= book.genre %></p>
                        </div>

                        <div class="flex items-center">
                            <span class="text-green-600">In Stock (<%=book.quantity%>)</span>
                            <br>
                        </div>

                        <div class="border-t border-b py-4">
                            <div class="flex items-baseline">
                                <span class="text-4xl font-bold text-gray-900">₹<%= book.price %></span>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <div class="flex items-center space-x-4">
                                <div class="flex items-center border rounded-lg">
                                    
                                    <button class="px-4 py-2 text-gray-600 hover:text-purple-600">
                                         <br>
                                    </button>
                                    <input type="number" value="1" min="1" max="23"
                                        class="text-center text-2xl focus:outline-none 
                                        [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                                    <button class="px-4 py-2 text-gray-600 hover:text-purple-600">
                                         <br>
                                    </button>
                                </div>
                                <button
                                    class="flex-1 bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition-colors">
                                    Buy Now
                                </button>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <button
                                    class="flex items-center justify-center space-x-2 border border-purple-600 text-purple-600 px-6 py-3 rounded-lg hover:bg-purple-50 transition-colors">
                                    <i class="fas fa-shopping-cart"></i>
                                    <span>Add to Cart</span>
                                </button>
                                <button
                                    class="flex items-center justify-center space-x-2 border border-purple-600 text-purple-600 px-6 py-3 rounded-lg hover:bg-purple-50 transition-colors">
                                    <i class="far fa-heart"></i>
                                    <span>Add to Wishlist</span>
                                </button>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <h3 class="text-lg font-semibold">Description</h3>
                            <p class="text-gray-600">
                                <%= book.description %>
                            </p>
                            
                        </div>
                    </div>
                </div>

                
                
            </div>

            <!-- Reviews Section -->
            <div class="mt-8">
                <h3 class="text-2xl font-bold mb-6">Customer Reviews</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="bg-white p-6 rounded-xl shadow-lg">
                        <div class="flex items-start space-x-4">
                            <img src="https://ui-avatars.com/api/?name=Sarah+Johnson" alt="Sarah Johnson"
                                class="w-12 h-12 rounded-full">
                            <div class="flex-1">
                                <div class="flex items-center justify-between">
                                    <h4 class="font-semibold">Sarah Johnson</h4>
                                    <span class="text-gray-500">2 days ago</span>
                                </div>
                                <div class="flex text-yellow-400 my-1">
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                </div>
                                <p class="text-gray-600">Absolutely loved this book! The concept is fascinating and the
                                    writing is beautiful. Couldn't put it down!</p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl shadow-lg">
                        <div class="flex items-start space-x-4">
                            <img src="https://ui-avatars.com/api/?name=Michael+Chen" alt="Michael Chen"
                                class="w-12 h-12 rounded-full">
                            <div class="flex-1">
                                <div class="flex items-center justify-between">
                                    <h4 class="font-semibold">Michael Chen</h4>
                                    <span class="text-gray-500">1 week ago</span>
                                </div>
                                <div class="flex text-yellow-400 my-1">
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="far fa-star"></i>
                                </div>
                                <p class="text-gray-600">A thought-provoking read that makes you reflect on your life
                                    choices. Well worth the investment.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="/js/script.js"></script>
</body>

</html>