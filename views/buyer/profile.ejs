					<span class="value">buyer</span>
				</div>
			</div>

			<div class="action-buttons">
				<button class="btn edit-btn">Edit Profile</button>
				<button class="btn logout-btn">Logout</button>
			</div>
		</div>

		<div class="orders-section">
			<h3 class="section-title">Your Orders</h3>
			<div class="order-card">
				<img src="https://images-na.ssl-images-amazon.com/images/I/51k2g+1roFL.SX331_BO1,204,203,200.jpg" alt="Book" class="book-image">
