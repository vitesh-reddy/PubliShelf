			</div>

			<div class="order-card">
				<img src="https://m.media-amazon.com/images/I/81FxtWdphnL.AC_UY218.jpg" alt="Book" class="book-image">
				<div class="order-details">
					<h4>Dune</h4>
					<p><strong>Author:</strong> Frank Herbert</p>
					<p><strong>Genre:</strong> Science Fiction</p>
					<p><strong>Price:</strong> ₹850</p>
					<p><strong>Quantity:</strong> 2</p>
					<p><strong>Description:</strong> Epic tale of interstellar politics and power</p>
				</div>
				<div class="order-actions">
					<span class="status">Shipped</span>
				</div>
			</div>

			<div class="order-card">
				<img src="https://m.media-amazon.com/images/I/91uwocAMtSL.AC_UY218.jpg" alt="Book" class="book-image">
				<div class="order-details">
					<h4>A Game of Thrones</h4>
					<p><strong>Author:</strong> George R.R. Martin</p>
					<p><strong>Genre:</strong> Fantasy</p>
					<p><strong>Price:</strong> ₹1299</p>
					<p><strong>Quantity:</strong> 1</p>
					<p><strong>Description:</strong> First book in A Song of Ice and Fire series</p>
				</div>
				<div class="order-actions">
					<span class="status">Processing</span>
				</div>
			</div>

			<div class="wishlist-section">
				<h3 class="section-title">Your Wishlist</h3>
				<div class="wishlist-grid">
					<div class="wishlist-item">
						<img src="https://m.media-amazon.com/images/I/81ls8LLUNJL.AC_UY218.jpg" alt="Book">
						<p>Sapiens</p>
						<p style="color: #666; font-size: 12px;">Yuval Noah Harari</p>
					</div>
					<div class="wishlist-item">
						<img src="https://m.media-amazon.com/images/I/71aFt4+OTOL.AC_UY218.jpg" alt="Book">
						<p>The Alchemist</p>
						<p style="color: #666; font-size: 12px;">Paulo Coelho</p>
					</div>
					<div class="wishlist-item">
						<img src="https://m.media-amazon.com/images/I/81YOuOGFCJL.AC_UY218.jpg" alt="Book">
						<p>1984</p>
						<p style="color: #666; font-size: 12px;">George Orwell</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</body>

</html>