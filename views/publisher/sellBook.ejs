<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PublicShelf - Sell Your Books</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f5f7fa;
            color: #333;
            line-height: 1.6;
        }

        header {
            background-color: white;
            padding: 10px 0;
            border-bottom: 1px solid #e0e0e0;
        }

        .header-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            color: #1a73e8;
            cursor: pointer;
            text-decoration: none;
        }

        .top-right {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .top-right a {
            text-decoration: none;
            color: #333;
        }

        .my-books {
            background-color: #7CB9E8;
            color: #333;
            font-weight: bold;
            padding: 8px 12px;
            border-radius: 4px;
            text-decoration: none;
        }

        .container {
            max-width: 800px;
            margin: 20px auto;
            background-color: white;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            padding: 20px;
            width: 95%;
        }

        .intro-text {
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 1px solid #e0e0e0;
        }

        .form-section h2 {
            margin-bottom: 20px;
            font-size: 18px;
            color: #333;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            font-size: 14px;
            color: #555;
        }

        .form-control {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 14px;
        }

        .form-control:focus {
            border-color: #1a73e8;
            box-shadow: 0 0 0 2px rgba(26, 115, 232, 0.2);
            outline: none;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
        }

        .checkbox-group input[type="checkbox"] {
            margin-right: 8px;
        }

        .radio-group {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
        }

        .radio-group input[type="radio"] {
            margin-right: 8px;
        }

        .info-text {
            font-size: 12px;
            color: #666;
            margin-top: 4px;
        }

        .separator {
            margin: 30px 0;
            border-top: 1px solid #e0e0e0;
        }

        .submit-button {
            background-color: #7CB9E8;
            color: #333;
            border: none;
            padding: 12px 24px;
            border-radius: 4px;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
            margin-top: 20px;
        }

        .submit-button:hover {
            background-color: #7CB9E8;
        }

        .terms-text {
            font-size: 12px;
            color: #666;
            margin-top: 12px;
            text-align: center;
        }

        .terms-text a {
            color: #1a73e8;
            text-decoration: none;
        }

        .success-message {
            background-color: #d4edda;
            color: #155724;
            padding: 10px;
            border-radius: 4px;
            margin-bottom: 16px;
            display: none;
        }

        /* Responsive styles */
    </style>
</head>

<body>
    <header>
        <div class="header-container">
            <a href="/" class="logo">PublicShelf</a>
            <div class="top-right">
                <a href="/publisher/dashboard" class="my-books">My Books</a>
                <a href="#">Sign In</a>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="intro-text">
            <h1>Submit Book Details</h1>
            <!-- <p>You will need books for sale to use this form.</p>
            <a href="#">Click here to know how it works!</a> -->
        </div>

        <div id="bookSuccessMessage" class="success-message">
            Book details submitted successfully!
        </div>

        <form id="bookForm">
            <div class="form-group">
                <label for="bookId">ID / ISBN</label>
                <input type="text" id="bookId" class="form-control">
            </div>

            <div class="form-group">
                <label for="bookName">Book Name</label>
                <input type="text" id="bookName" class="form-control" required>
            </div>

            <div class="form-group">
                <label for="bookAuthor">Author Name</label>
                <input type="text" id="bookAuthor" class="form-control" required>
            </div>

            <!-- <div class="checkbox-group">
                <input type="checkbox" id="saleTradeAllowed">
                <label for="saleTradeAllowed">Sale/Trade through website</label>
            </div>
            
            <div class="checkbox-group">
                <input type="checkbox" id="directBuying">
                <label for="directBuying">Allow direct buying for higher commission</label>
            </div> -->

            <div class="form-group">
                <label for="bookImage">Upload Book Image</label>
                <input type="url" id="bookImage" class="form-control" required placeholder="Enter image URL">
            </div>

            <div class="form-group">
                <label for="bookType">Book Type</label>
                <select id="bookType" class="form-control">
                    <option value="">Please select book type</option>
                    <option value="fiction">Fiction</option>
                    <option value="non-fiction">Non-Fiction</option>
                    <option value="textbook">Textbook</option>
                    <option value="reference">Reference</option>
                </select>
            </div>

            <div class="form-group">
                <label>Book Condition</label>
                <div class="radio-group">
                    <input type="radio" name="condition" id="conditionExcellent" value="excellent">
                    <label for="conditionExcellent">Excellent</label>
                </div>
                <div class="radio-group">
                    <input type="radio" name="condition" id="conditionGood" value="good">
                    <label for="conditionGood">Good</label>
                </div>
                <div class="radio-group">
                    <input type="radio" name="condition" id="conditionFair" value="fair">
                    <label for="conditionFair">Fair</label>
                </div>
            </div>

            <div class="form-group">
                <label for="bookQuality">Book Quality</label>
                <select id="bookQuality" class="form-control" required>
                    <option value="">Select quality</option>
                    <option value="high">High</option>
                    <option value="medium">Medium</option>
                    <option value="low">Low</option>
                </select>
            </div>

            <div class="form-group">
                <label for="bookQuantity">Quantity Available</label>
                <input type="number" id="bookQuantity" class="form-control" min="1" value="1">
            </div>

            <div class="separator"></div>

            <h2>Pricing Details</h2>

            <div class="form-group">
                <label for="bookPrice">Your Price ($)</label>
                <input type="number" id="bookPrice" class="form-control" min="0" step="0.01" required>
            </div>

            <div class="form-group">
                <label for="shippingCharge">Your Shipping Charge ($)</label>
                <div style="display: flex; align-items: center;">
                    <input type="number" id="shippingCharge" class="form-control" min="0" step="0.01"
                        style="margin-right: 10px;">
                    <span>Free Shipping</span>
                </div>
            </div>

            <div class="form-group">
                <label>Payment Method</label>
                <div class="checkbox-group">
                    <input type="checkbox" id="payByCard">
                    <label for="payByCard">Accept card payment</label>
                </div>
            </div>

            <button type="submit" class="submit-button">Submit Book</button>
        </form>

        <div class="terms-text">
            By using this form, you acknowledge and agree to our <a href="#">Terms of Use</a> and <a href="#">Privacy
                Policy</a>
        </div>
    </div>

    <script>
        // Store submitted books
        let books = JSON.parse(localStorage.getItem('books')) || [];

        // Book form submission
        document.getElementById('bookForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const bookData = {
                id: document.getElementById('bookId').value || Date.now().toString(),
                name: document.getElementById('bookName').value,
                author: document.getElementById('bookAuthor').value,
                image: document.getElementById('bookImage').value,
                price: parseFloat(document.getElementById('bookPrice').value),
                quality: document.getElementById('bookQuality').value,
                type: document.getElementById('bookType').value,
                condition: document.querySelector('input[name="condition"]:checked')?.value || '',
                quantity: parseInt(document.getElementById('bookQuantity').value) || 1,
                shippingCharge: parseFloat(document.getElementById('shippingCharge').value) || 0,
                saleTradeAllowed: document.getElementById('saleTradeAllowed').checked,
                directBuying: document.getElementById('directBuying').checked,
                payByCard: document.getElementById('payByCard').checked
            };

            books.push(bookData);
            localStorage.setItem('books', JSON.stringify(books));

            // Show success message
            const successMessage = document.getElementById('bookSuccessMessage');
            successMessage.style.display = 'block';
            setTimeout(() => {
                successMessage.style.display = 'none';
            }, 3000);

            // Reset form
            this.reset();
        });

        // Initial setup
        document.addEventListener('DOMContentLoaded', function () {
            // Nothing to display on this page
        });
    </script>
</body>

</html>